<resources>
    <!-- App theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Toolbar background -->
        <item name="colorPrimary">#FFAB40</item>
        <item name="colorPrimaryDark">#FFAB40</item>
        <item name="colorAccent">#FFAB40</item>

        <!-- Popup menu style -->
        <item name="popupMenuStyle">@style/PopupMenuStyle</item>
        <item name="actionOverflowMenuStyle">@style/PopupMenuStyle</item>
    </style>

    <!-- Custom popup menu style -->
    <style name="PopupMenuStyle" parent="ThemeOverlay.AppCompat.Light">
        <!-- Background color of overflow menu -->
        <item name="android:popupBackground">#FFAB40</item>
        <!-- Force text color for menu items -->
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textAppearance">@style/PopupMenuTextAppearance</item>
    </style>

    <!-- Text appearance for menu items -->
    <style name="PopupMenuTextAppearance" parent="TextAppearance.AppCompat.Widget.PopupMenu.Large">
        <item name="android:textColor">@android:color/white</item>
    </style>
</resources>
